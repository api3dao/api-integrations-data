    },
    {
      "name": "CoinMetrics",
      "item": [
        {
          "name": "Crypto",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.coinmetrics.io/v4/timeseries/asset-metrics?api_key={{coinmetrics_apiKey}}&assets=aave,btc&metrics=ReferenceRate&frequency=1s&limit_per_asset=1&page_size=200",
              "protocol": "https",
              "host": ["api", "coinmetrics", "io"],
              "path": ["v4", "timeseries", "asset-metrics"],
              "query": [
                {
                  "key": "api_key",
                  "value": "{{coinmetrics_apiKey}}"
                },
                {
                  "key": "assets",
                  "value": "aave,btc"
                },
                {
                  "key": "metrics",
                  "value": "ReferenceRate"
                },
                {
                  "key": "frequency",
                  "value": "1s"
                },
                {
                  "key": "limit_per_asset",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "200"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
